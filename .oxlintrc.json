{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "import",
    "node",
    "react",
    "react-perf",
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "@typescript-eslint/consistent-type-definitions": ["error", "type"],
    "curly": ["error", "all"]
  },
  "env": {
    "builtin": true
  }
}
