{
  "name": "fckgit",
  "version": "1.6.2",
  "description": "A fullscreen TUI Git client",
  "keywords": [
    "cli",
    "git",
    "terminal",
    "tui"
  ],
  "license": "ISC",
  "author": "tu4mo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tu4mo/fckgit.git"
  },
  "bin": {
    "fckgit": "dist/app.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "rm -rf dist && rolldown --config rolldown.config.js",
    "dev": "tsx --watch src/app.tsx",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepublishOnly": "npm run build",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@shikijs/cli": "4.2.0",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "ink": "7.1.0",
    "ink-scroll-list": "0.4.1",
    "ink-scroll-view": "0.3.7",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "parse-diff": "0.12.0",
    "react": "19.2.7",
    "rolldown": "1.1.2",
    "slice-ansi": "9.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
