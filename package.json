{
  "name": "fckgit",
  "version": "1.0.2",
  "description": "A fullscreen TUI Git client",
  "keywords": [
    "git",
    "tui",
    "cli",
    "terminal"
  ],
  "license": "ISC",
  "author": "tu4mo",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu4mo/fckgit.git"
  },
  "type": "module",
  "main": "dist/app.js",
  "bin": {
    "fckgit": "dist/app.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown --config rolldown.config.js",
    "dev": "tsx --watch src/app.tsx",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepublishOnly": "npm run build",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "7.1.0",
    "ink-scroll-list": "0.4.1",
    "ink-scroll-view": "0.3.7",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "rolldown": "1.1.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
